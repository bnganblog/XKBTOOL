<UserControl
    x:Class="ToolboxWinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- 关于 -->
            <Border x:Name="aboutCard"
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="关于" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="显卡吧工具箱WinUI3" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock x:Name="verText" FontSize="13" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Windows 硬件检测与系统工具" FontSize="13" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 主题 -->
            <Border x:Name="themeCard"
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Border Width="44" Height="44" CornerRadius="8" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE771;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="主题" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="切换深浅皮肤" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <ComboBox x:Name="themeCombo" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Right" MinWidth="140" VerticalAlignment="Center">
                        <ComboBoxItem Content="浅色模式"/>
                        <ComboBoxItem Content="深色毛玻璃"/>
                        <ComboBoxItem Content="浅色毛玻璃"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 工具管理 -->
            <Border x:Name="toolsCard"
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="工具管理" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Button x:Name="resetBtn" Content="恢复默认工具" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="16,6"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="exportBtn" Content="导出工具配置" Padding="16,6"/>
                        <Button x:Name="importBtn" Content="导入工具配置" Padding="16,6"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
