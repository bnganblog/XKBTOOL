<Window
    x:Class="ToolboxWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="显卡吧工具箱WinUI3"
    x:Name="mainWindowRoot">

    <Grid x:Name="rootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 自定义标题栏（扩展至非客户区） -->
        <Grid x:Name="titleBar" 
              Grid.Row="0" 
              Height="40"
              Background="Transparent"
              Canvas.ZIndex="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="backBtn"
                    Grid.Column="0"
                    Width="48"
                    Height="40"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BackBtn_Click"
                    Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                    Visibility="Collapsed">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="14"/>
            </Button>
            <Button x:Name="paneToggleBtn"
                    Grid.Column="1"
                    Width="48"
                    Height="40"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="PaneToggleBtn_Click"
                    Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" FontSize="14"/>
            </Button>
            <TextBlock x:Name="titleText" 
                       Grid.Column="2" 
                        Text="显卡吧工具箱WinUI3"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Margin="4,0,0,0"/>
            <TextBlock x:Name="versionText" 
                       Grid.Column="3"
                       Text="v1.0.0"
                       FontSize="11"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>

        <NavigationView x:Name="navView"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        IsPaneOpen="True"
                        IsPaneToggleButtonVisible="False"
                         IsBackButtonVisible="Collapsed"
                         OpenPaneLength="240"
                        SelectionChanged="NavView_SelectionChanged"
                        AlwaysShowHeader="True"
                        IsSettingsVisible="False"
                        ExpandedModeThresholdWidth="1200"
                        CompactModeThresholdWidth="600">
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="28" FontWeight="SemiBold" Margin="-20,-24,0,0"/>
                </DataTemplate>
            </NavigationView.HeaderTemplate>
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="navSystem" Content="系统信息" Tag="system">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF120;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navFavorites" Content="收藏夹" Tag="favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE734;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navCpu" Content="CPU工具" Tag="CPU工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEEA1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navGpu" Content="显卡工具" Tag="显卡工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF211;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navRam" Content="内存工具" Tag="内存工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEEA0;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navDisk" Content="硬盘工具" Tag="硬盘工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7F1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navPeripheral" Content="外设工具" Tag="外设工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE765;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navStress" Content="烤鸡工具" Tag="烤鸡工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE945;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navNetwork" Content="网络工具" Tag="network">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE774;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navOther" Content="其他工具" Tag="其他工具">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7C3;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="navStore" Content="工具商店" Tag="工具商店">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE719;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Button x:Name="settingsBtn"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="16,8"
                        Click="SettingsBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" FontSize="14"/>
                        <TextBlock Text="  设置" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                </Button>
            </NavigationView.PaneFooter>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid x:Name="contentArea" Margin="24,8,24,24"/>
            </ScrollViewer>
        </NavigationView>
        <Grid x:Name="downloadFooter" Grid.Row="2" Height="36" Visibility="Collapsed" Background="{ThemeResource SystemChromeMediumLowColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="downloadProgressBar" Height="4" VerticalAlignment="Bottom" IsIndeterminate="True"/>
            <TextBlock x:Name="downloadStatusText" Grid.Column="1" Text="" FontSize="12" VerticalAlignment="Center" Margin="12,0,16,0"/>
        </Grid>
    </Grid>
</Window>
