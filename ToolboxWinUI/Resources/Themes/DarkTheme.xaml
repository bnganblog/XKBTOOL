<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="AccentColor">#FF60CDFF</Color>
    <Color x:Key="BackgroundColor">#FF1E1E1E</Color>
    <Color x:Key="CardBackgroundColor">#FF2D2D2D</Color>
    <Color x:Key="TextPrimaryColor">#FFE0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#FF9C9C9C</Color>
    <Color x:Key="BorderColor">#FF3D3D3D</Color>
    <Color x:Key="HoverColor">#FF3A3A3A</Color>
    <Color x:Key="PressedColor">#FF4A4A4A</Color>
    <Color x:Key="SidebarColor">#FF252525</Color>
    <Color x:Key="ChartCpuColor">#FF60CDFF</Color>
    <Color x:Key="ChartMemColor">#FF4CAF50</Color>
    <Color x:Key="ChartGpuColor">#FFF44336</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="PressedBrush" Color="{StaticResource PressedColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="ChartCpuBrush" Color="{StaticResource ChartCpuColor}"/>
    <SolidColorBrush x:Key="ChartMemBrush" Color="{StaticResource ChartMemColor}"/>
    <SolidColorBrush x:Key="ChartGpuBrush" Color="{StaticResource ChartGpuColor}"/>
</ResourceDictionary>
